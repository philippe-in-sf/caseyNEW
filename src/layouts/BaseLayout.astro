---
import '../styles/global.css';
import { navigation, site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const pageTitle = title === site.title ? title : `${title} | ${site.name}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
const baseUrl = import.meta.env.BASE_URL;
const trimmedBase = baseUrl.replace(/^\/+|\/+$/g, '');
const basePrefix = trimmedBase.length > 0 ? `/${trimmedBase}` : '';

function toInternalHref(path: string) {
  if (path === '/') {
    return basePrefix ? `${basePrefix}/` : '/';
  }
  if (!path.startsWith('/')) {
    return path;
  }
  return `${basePrefix}/${path.replace(/^\/+/, '')}`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={toInternalHref('/')} aria-label={`${site.name} home`}>{site.name}</a>
      <nav class="nav" aria-label="Primary navigation">
        {navigation.map((item) => <a href={toInternalHref(item.href)}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; 2026 {site.name}. All rights reserved.</p>
      <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
    </footer>
  </body>
</html>
