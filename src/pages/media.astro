---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Media" description="Selected media, recordings, and features for Casey Cantwell.">
  <PageHeader eyebrow="Media" title="Media" description="Selected recordings, videos, and features will be collected here as approved links become available." />
  <section class="section media-grid">
    <article class="media-card">
      <p class="eyebrow">Video</p>
      <h2>Improvisation</h2>
      <p>Future media entry for a recording or video of Casey's improvisation.</p>
    </article>
    <article class="media-card">
      <p class="eyebrow">Feature</p>
      <h2>The Organ at Trinity</h2>
      <p>Future feature space for organ and church music context at Trinity Episcopal Church.</p>
    </article>
    <article class="media-card">
      <p class="eyebrow">Archive</p>
      <h2>Concert Recordings</h2>
      <p>Selected concert media can be added here without changing the site structure.</p>
    </article>
  </section>
</BaseLayout>
