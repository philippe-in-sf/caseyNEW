---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCallout from '../components/ContactCallout.astro';
import PageHeader from '../components/PageHeader.astro';
import ScheduleList from '../components/ScheduleList.astro';
import SeasonOverview from '../components/SeasonOverview.astro';
import { evensongRecitals, specialEvents, sundayServiceMusic, tuesdaysAtTrinity } from '../data/musicSchedule';

const page = await getEntry('pages', 'trinity-music');
if (!page) {
  throw new Error('Missing Trinity Music page content');
}
const { Content } = await page.render();
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <PageHeader eyebrow={page.data.eyebrow} title={page.data.title} description={page.data.description} />
  <section class="section split">
    <div>
      <h2>Music at Trinity</h2>
      <SeasonOverview />
    </div>
    <div class="prose">
      <Content />
    </div>
  </section>
  <section class="section">
    <p class="eyebrow">Sunday Schedule</p>
    <h2>All Sunday service music listings</h2>
    <ScheduleList events={sundayServiceMusic} />
  </section>
  <section class="section">
    <p class="eyebrow">Service Music</p>
    <h2>Recitals preceding Evensong</h2>
    <ScheduleList events={evensongRecitals} />
  </section>
  <section class="section">
    <p class="eyebrow">Concert Series</p>
    <h2>Tuesdays at Trinity</h2>
    <ScheduleList events={tuesdaysAtTrinity} />
  </section>
  <section class="section">
    <p class="eyebrow">Special Events</p>
    <h2>Choral services and concerts</h2>
    <ScheduleList events={specialEvents} />
  </section>
  <ContactCallout title="For Trinity music questions" body="Use the contact address for concise music-program inquiries and service music coordination." />
</BaseLayout>
